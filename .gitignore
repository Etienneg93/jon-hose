# build output (CI rebuilds it; Pages serves it)
dist/

# node
node_modules/
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/

# API keys / secrets
.env
.env.*

# raw generated artwork — source/scratch, never loaded by the game
sprites/**/gen/

# editable art sources (Aseprite) — the game loads the exported PNGs, not these
*.aseprite
*.ase
