# build output (CI rebuilds it; Pages serves it)
dist/

# node
node_modules/
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/

# API keys / secrets
.env
.env.*

# AI-generated artwork (Gemini) — local reference/scratch only, never committed
generated-art/

# raw generated artwork — source/scratch, never loaded by the game
sprites/**/gen/

# itch.io effect packs — local picking library; curated frames live in sprites/fx/
sprites/effects/

# editable art sources (Aseprite) — the game loads the exported PNGs, not these
*.aseprite
*.ase

# truck-sprite debug artifacts
sprites/firetruck/_clean.png
sprites/firetruck/_debug.png
sprites/firetruck/_drive4x.png
